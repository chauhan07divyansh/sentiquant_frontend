# ─────────────────────────────────────────────
#  SENTIQUANT — Environment Variables
#  Copy this file to .env.local and fill in values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# ── Flask Backend URL ─────────────────────────
# Used by the browser for direct API calls (dev only)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Used by Next.js server-side proxy (production)
# This URL is NEVER exposed to the browser
FLASK_INTERNAL_URL=http://localhost:5000

# ── NextAuth.js ───────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string-32-chars-min

# ── Optional: Google OAuth (if added later) ───
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
